# Automatic HTTPS (Let's Encrypt) for both apps. Point two DNS A-records at
# the EC2 elastic IP and set the domains here. WebRTC mic access REQUIRES https.

# Apex: the landing/portal page (static). Left-pane tabs load the apps below.
{$BASE_DOMAIN} {
    root * /srv/landing
    file_server
}

www.{$BASE_DOMAIN} {
    redir https://{$BASE_DOMAIN}{uri} permanent
}

desk.{$BASE_DOMAIN} {
    reverse_proxy desk:8000
}

gex.{$BASE_DOMAIN} {
    reverse_proxy gex-api:3000
}

obs.{$BASE_DOMAIN} {
    reverse_proxy observatory:8321
}

bank.{$BASE_DOMAIN} {
    reverse_proxy minibank:8080
}

# One hostname, three services behind it, routed by path. The browser sees a
# single origin; /api/analytics is answered by a different process with a
# different database from everything else on this host. Path routing at the
# edge is what lets a service be split out without the front end noticing.
mart.{$BASE_DOMAIN} {
    handle /api/analytics/* {
        reverse_proxy minimart:8083
    }
    handle {
        reverse_proxy minimart:8081
    }
}

pay.{$BASE_DOMAIN} {
    reverse_proxy minimart:8082
}

# Anyone hitting the raw IP gets sent to the real site (secure context needed
# for mic + crypto APIs anyway).
:80 {
    redir https://desk.{$BASE_DOMAIN}{uri} permanent
}
