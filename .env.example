# --- Required: one key powers everything (LLMs, embeddings, Realtime voice) ---
OPENAI_API_KEY=sk-...

# --- Optional: xAI key enables the X pulse (live X chatter via Grok x_search) ---
XAI_API_KEY=

# --- Recommended: free observability for every agent run ---
# https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-trading-desk

# --- Optional overrides ---
# Chat model used by all text agents (any langchain init_chat_model string)
DESK_MODEL=openai:gpt-4.1
# Point Agent 2 at a live options-flow-analytics Postgres instead of the bundled SQLite
# DATABASE_URL=postgresql://user:pass@localhost:5432/options
# Path to a checkout of the options-flow-analytics repo for Agent 3 indexing
# GEX_REPO_PATH=../options-flow-analytics
